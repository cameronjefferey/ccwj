# HappyTrader - copy to .env and fill in values

# Required: Flask session encryption (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Required: Postgres connection string. Local dev example:
#   DATABASE_URL=postgresql://localhost:5432/happytrader
# Render injects this automatically when you link a Postgres database to the web service.
DATABASE_URL=

# Optional: tune connection pool (Render/managed Postgres: defaults reduce stale TLS errors)
# DATABASE_POOL_MAX=12
# DATABASE_POOL_TIMEOUT=60
# DATABASE_POOL_MAX_IDLE=300
# DATABASE_POOL_MAX_LIFETIME=1800

# BigQuery: use gcloud auth application-default login, or set one of:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON_BASE64=base64-encoded-json

# Optional: AI insights (get key at https://aistudio.google.com)
GEMINI_API_KEY=

# Optional: User accounts to seed at startup (format: username:password,username2:password2)
# Prefer `flask create-user` once the DB is set up; remove this once seeded so plaintext
# passwords don't sit in env vars.
HAPPYTRADER_USERS=

# Optional: Admin usernames (comma-separated, see all accounts)
ADMIN_USERS=

# Manual CSV upload → commits dbt seeds in this repo and triggers GitHub Actions
# Classic PAT: repo scope. Fine-grained: Contents Read/Write on the repo.
GITHUB_PAT=
# Optional: override if your fork or org differs (default cameronjefferey/ccwj)
# GITHUB_REPO=owner/ccwj
# Optional: branch for seed files (default master — must match
# .github/workflows/bigquery_update.yml push branches, e.g. master or main, or the
# workflow will not run after Schwab/CSV seed commits)
# GITHUB_BRANCH=master
# Optional: max upload size in MB (default 32)
# MAX_UPLOAD_MB=32

# Optional: Schwab API for Connect Schwab / daily sync (see docs/SCHWAB_API_SETUP.md)
# Callback must be HTTPS and match the Schwab portal (Schwab rejects http://127.0.0.1).
# Local dev: use an HTTPS tunnel URL, e.g. https://xxxx.ngrok-free.app/schwab/callback
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=
# Routine rolling lookback (days) for "rolling" syncs, cron, and after your first in-app sync.
# First sync in the app can still request up to ~5 years (1825) from the Profile → Accounts form.
# SCHWAB_SYNC_TRANSACTION_DAYS=120

# Optional: Sentry error reporting (no default in code — set to enable)
SENTRY_DSN=

# Production hardening (Render sets RENDER=true automatically)
# FLASK_PRODUCTION=true  # or rely on RENDER=true for secure cookies
# SESSION_COOKIE_SECURE=true
# SIGNUP_ENABLED=false     # hide /signup completely (returns 404)
# SIGNUP_INVITE_CODE=       # closed-beta gate: when set, /signup form requires this code
# WTF_CSRF_ENABLED=true    # default on; set false only for local debugging
