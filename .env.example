# HappyTrader - copy to .env and fill in values

# Required: Flask session encryption (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Required: Postgres connection string. Local dev example:
#   DATABASE_URL=postgresql://localhost:5432/happytrader
# Render injects this automatically when you link a Postgres database to the web service.
DATABASE_URL=

# Optional: tune connection pool (Render/managed Postgres: defaults reduce stale TLS errors)
# DATABASE_POOL_MAX=12
# DATABASE_POOL_TIMEOUT=60
# DATABASE_POOL_MAX_IDLE=300
# DATABASE_POOL_MAX_LIFETIME=1800

# BigQuery: use gcloud auth application-default login, or set one of:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON_BASE64=base64-encoded-json

# Optional: AI insights. The narration layer (app/llm.py) is provider-agnostic.
# LLM_PROVIDER picks the vendor for /insights and /strategy-fit narration:
#   gemini (default) -> needs GEMINI_API_KEY  (key: https://aistudio.google.com)
#   claude           -> needs ANTHROPIC_API_KEY (key: https://console.anthropic.com)
# LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# In-product model picker: users choose a model on /insights from an
# allowlist (saved per-user). SELECTABLE_LLM_MODELS is a comma-separated
# list of catalog keys (see MODEL_CATALOG in app/llm.py). A model only
# appears if its vendor key above is set. Defaults to the low-cost set;
# add paid keys here to offer them.
#   keys: gemini-2.5-flash, claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-8
# SELECTABLE_LLM_MODELS=gemini-2.5-flash,claude-haiku-4-5
# LLM_PROVIDER (above) is now only a tie-breaker for the default pick when a
# user hasn't chosen a model yet.

# Optional: User accounts to seed at startup (format: username:password,username2:password2)
# Prefer `flask create-user` once the DB is set up; remove this once seeded so plaintext
# passwords don't sit in env vars.
HAPPYTRADER_USERS=

# Optional: Admin usernames (comma-separated, see all accounts)
ADMIN_USERS=

# Manual CSV upload → commits dbt seeds in this repo and triggers GitHub Actions
# Classic PAT: repo scope. Fine-grained: Contents Read/Write on the repo.
GITHUB_PAT=
# Optional: override if your fork or org differs (default cameronjefferey/ccwj)
# GITHUB_REPO=owner/ccwj
# Optional: branch for seed files (default master — must match
# .github/workflows/bigquery_update.yml push branches, e.g. master or main, or the
# workflow will not run after Schwab/CSV seed commits)
# GITHUB_BRANCH=master
# Optional: max upload size in MB (default 32)
# MAX_UPLOAD_MB=32

# Optional: Schwab API for Connect Schwab / daily sync (see docs/SCHWAB_API_SETUP.md)
# Callback must be HTTPS and match the Schwab portal (Schwab rejects http://127.0.0.1).
# Local dev: use an HTTPS tunnel URL, e.g. https://xxxx.ngrok-free.app/schwab/callback
# Outbound email. Three backends (EMAIL_BACKEND): 'log' (default — writes the
# email to the app logger so the operator can paste reset links during closed
# beta, no creds needed), 'smtp' (any SMTP provider), 'resend' (Resend HTTP
# API). See docs/EMAIL_STRATEGY.md for provider setup + DNS. EMAIL_FROM must
# be on a domain verified with your provider.
# EMAIL_BACKEND=log
# EMAIL_FROM=HappyTrader <noreply@happytrader.me>
#
# --- Provider A: Resend SMTP (zero-code transactional; ship password reset) ---
# EMAIL_BACKEND=smtp
# EMAIL_SMTP_HOST=smtp.resend.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=resend
# EMAIL_SMTP_PASSWORD=re_your_api_key
# EMAIL_SMTP_USE_SSL=0   # 1 for direct TLS (port 465); default starttls.
#
# --- Provider B: Resend HTTP API (needed for rich digests / List-Unsubscribe) ---
# EMAIL_BACKEND=resend
# RESEND_API_KEY=re_your_api_key
#
# Resend delivery webhook (bounce/complaint suppression). Create a webhook in
# Resend pointing at <APP_BASE_URL>/webhooks/resend and paste its signing
# secret here. If unset, the endpoint skips signature verification (dev only).
# RESEND_WEBHOOK_SECRET=whsec_your_secret

# Absolute origin used to build links in emails sent outside a request context
# (the digest crons + SnapTrade reconnect notice). Set to your local URL in dev.
# APP_BASE_URL=https://happytrader.me

# Optional: SnapTrade aggregator (Fidelity, Vanguard, Robinhood, IBKR, ...).
# Consumer Key is a bearer secret — never commit. See docs/SNAPTRADE_SETUP.md.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_REDIRECT_URI=http://127.0.0.1:5000/snaptrade/callback
# SnapTrade userIds are GLOBAL to the clientId. When dev/staging share a
# clientId with prod, set a per-environment namespace so local connect/sync
# can't collide with (or rotate the secret of) a real prod user. Leave EMPTY
# in production; set e.g. "local" in dev → registers happytrader-local-<id>.
# SNAPTRADE_USER_NAMESPACE=local

SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=
# Routine rolling lookback (days) for "rolling" syncs, cron, and after your first in-app sync.
# First sync in the app can still request up to ~5 years (1825) from the Profile → Accounts form.
# SCHWAB_SYNC_TRANSACTION_DAYS=120

# Optional: Sentry error reporting (no default in code — set to enable)
SENTRY_DSN=

# Production hardening (Render sets RENDER=true automatically)
# FLASK_PRODUCTION=true  # or rely on RENDER=true for secure cookies
# SESSION_COOKIE_SECURE=true
# SIGNUP_ENABLED=false     # hide /signup completely (returns 404)
# SIGNUP_INVITE_CODE=       # closed-beta gate: when set, /signup form requires this code
# WTF_CSRF_ENABLED=true    # default on; set false only for local debugging
# RATELIMIT_STORAGE_URI=redis://host:6379/0
#   Optional: shared rate-limit counter store. Default 'memory://' is per-
#   gunicorn-worker, so caps multiply by worker count. Switch to Redis to
#   make a 30/day cap actually mean 30/day across the deployment.
